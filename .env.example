# ────────────────────────────────────────────────────────────
# Application
# ────────────────────────────────────────────────────────────
APP_NAME=Nodus Protocol API
APP_ENV=development          # development | production
FRONTEND_URL=http://localhost:3000

# ────────────────────────────────────────────────────────────
# Server
# ────────────────────────────────────────────────────────────
SERVER_PORT=8080
SERVER_READ_TIMEOUT=10s
SERVER_WRITE_TIMEOUT=30s
SERVER_IDLE_TIMEOUT=120s

# ────────────────────────────────────────────────────────────
# PostgreSQL
# ────────────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=nodus_protocol
DB_SSLMODE=disable           # disable | require | verify-full
DB_AUTOMIGRATE=false         # set true to auto-run GORM migrations

# ────────────────────────────────────────────────────────────
# Redis
# ────────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# ────────────────────────────────────────────────────────────
# JWT (RS256)
# ────────────────────────────────────────────────────────────
JWT_PRIVATE_KEY_PATH=./certs/private.pem
JWT_PUBLIC_KEY_PATH=./certs/public.pem
JWT_ACCESS_TTL=15m           # Access token lifetime
JWT_REFRESH_TTL=168h         # Refresh token lifetime (7 days)
JWT_EMAIL_TTL=24h            # Email verification link lifetime
JWT_PASSWORD_RESET_TTL=1h   # Password reset link lifetime

# ────────────────────────────────────────────────────────────
# SMTP Email
# ────────────────────────────────────────────────────────────
SMTP_HOST=smtp.mailgun.org   # or smtp.sendgrid.net / smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-smtp-user
SMTP_PASSWORD=your-smtp-password
SMTP_FROM=noreply@nodus-protocol.io
SMTP_FROM_NAME=Nodus Protocol

# ────────────────────────────────────────────────────────────
# Logging
# ────────────────────────────────────────────────────────────
LOG_LEVEL=info               # debug | info | warn | error
LOG_FORMAT=json              # json | console
