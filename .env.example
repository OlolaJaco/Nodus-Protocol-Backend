# ─────────────────────────────────────────────────────────────
# Application
# ─────────────────────────────────────────────────────────────
APP_NAME=Nodus Protocol API
APP_ENV=development          # development | production
FRONTEND_URL=http://localhost:3000

# ─────────────────────────────────────────────────────────────
# Server
# ─────────────────────────────────────────────────────────────
SERVER_PORT=8080
SERVER_READ_TIMEOUT=10s
SERVER_WRITE_TIMEOUT=30s
SERVER_IDLE_TIMEOUT=120s

# ─────────────────────────────────────────────────────────────
# PostgreSQL
# ─────────────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=nodus_protocol
DB_SSLMODE=disable
DB_AUTOMIGRATE=false         # set true to auto-run GORM migrations

# ─────────────────────────────────────────────────────────────
# Redis
# ─────────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# ─────────────────────────────────────────────────────────────
# JWT (RS256)
# ─────────────────────────────────────────────────────────────
JWT_PRIVATE_KEY_PATH=./certs/private.pem
JWT_PUBLIC_KEY_PATH=./certs/public.pem
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=168h
JWT_EMAIL_TTL=24h
JWT_PASSWORD_RESET_TTL=1h

# ─────────────────────────────────────────────────────────────
# SMTP Email
# ─────────────────────────────────────────────────────────────
SMTP_HOST=smtp.mailgun.org
SMTP_PORT=587
SMTP_USERNAME=your-smtp-user
SMTP_PASSWORD=your-smtp-password
SMTP_FROM=noreply@nodus-protocol.io
SMTP_FROM_NAME=Nodus Protocol

# ─────────────────────────────────────────────────────────────
# Core Engine  (Nodus-Protocol-Core-Engine service)
# ─────────────────────────────────────────────────────────────
CORE_ENGINE_URL=http://localhost:8081
CORE_ENGINE_TIMEOUT=15s

# ─────────────────────────────────────────────────────────────
# Stellar / Soroban  (Nodus-Protocol-Smart-Contract)
# ─────────────────────────────────────────────────────────────
STELLAR_NETWORK=testnet      # testnet | mainnet
HORIZON_URL=https://horizon-testnet.stellar.org
SOROBAN_RPC_URL=https://soroban-testnet.stellar.org
POOL_CONTRACT_ID=            # 32-byte hex or base64 of the deployed NodusAmm contract
POOL_TOKEN_0=XLM             # First token symbol (must match contract token_0)
POOL_TOKEN_1=USDC            # Second token symbol (must match contract token_1)

# ─────────────────────────────────────────────────────────────
# Logging
# ─────────────────────────────────────────────────────────────
LOG_LEVEL=info               # debug | info | warn | error
LOG_FORMAT=json              # json | console
